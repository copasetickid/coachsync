<div class="container mx-auto px-4 py-8">
  <div class="mb-6 flex justify-between items-center">
    <h1 class="text-2xl font-bold">Coaching Session Details</h1>

    <%= link_to "Back", current_user.coach? ? session_feedbacks_path : bookings_path,
                class: "text-indigo-600 hover:text-indigo-800" %>
  </div>

  <% if current_user == @coach && @coaching_session.status == 'scheduled' && @coaching_session.availability.end_time < Time.current %>
    <%= link_to "Provide Feedback", edit_session_feedback_path(@coaching_session),
                class: "bg-green-600 text-white py-2 px-6 rounded-md hover:bg-green-700" %>
  <% end %>

  <div class="bg-white shadow overflow-hidden rounded-lg mb-8">
    <div class="px-4 py-5 sm:px-6 bg-gray-50">
      <h2 class="text-lg font-medium text-gray-900">
        Session Information
      </h2>
    </div>

    <div class="border-t border-gray-200">
      <dl>
        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Date</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <%= @availability.start_time.strftime("%A, %B %d, %Y") %>
          </dd>
        </div>

        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Time</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <%= @availability.start_time.strftime("%I:%M %p") %> -
            <%= @availability.end_time.strftime("%I:%M %p") %>
          </dd>
        </div>

        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Coach</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <%= @coach.name %>
          </dd>
        </div>

        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Student</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <%= @student.name %>
          </dd>
        </div>

        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Status</dt>
          <dd class="mt-1 text-sm sm:mt-0 sm:col-span-2">
            <% case @coaching_session.status %>
            <% when 'scheduled' %>
              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                Scheduled
              </span>
            <% when 'completed' %>
              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                Completed
              </span>
            <% when 'cancelled' %>
              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">
                Cancelled
              </span>
            <% end %>
          </dd>
        </div>

        <% if @coaching_session.notes.present? %>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Notes</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2 whitespace-pre-line">
              <%= @coaching_session.notes %>
            </dd>
          </div>
        <% end %>

        <% if @coaching_session.satisfaction_score.present? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Satisfaction Score</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <div class="flex items-center">
                <% @coaching_session.satisfaction_score.times do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                <% end %>
                <% (5 - @coaching_session.satisfaction_score).times do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                <% end %>
              </div>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

  <% if @coaching_session.status == 'scheduled' %>
    <div class="flex flex-col md:flex-row space-y-4 md:space-y-0 md:space-x-4">
      <% if current_user == @coach && @coaching_session.availability.end_time < Time.current %>
        <!-- Coach can mark the session as completed after it has ended -->
        <%= link_to "Provide Feedback", edit_session_feedback_path(@coaching_session),
                    class: "bg-green-600 text-white py-2 px-6 rounded-md hover:bg-green-700 text-center" %>
      <% end %>

      <% if @coaching_session.availability.start_time > Time.current %>
        <!-- Both coach and student can cancel upcoming sessions -->
        <%= button_to "Cancel Session", cancel_coaching_session_path(@coaching_session),
                      method: :post,
                      data: { confirm: "Are you sure you want to cancel this session?" },
                      class: "bg-red-100 text-red-800 py-2 px-6 rounded-md hover:bg-red-200 text-center" %>
      <% end %>
    </div>
  <% end %>
</div>