<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <!-- Profile Card -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="p-6">
      <h2 class="text-xl font-semibold mb-4">Your Profile</h2>
      <div class="flex items-center mb-6">
        <div class="bg-purple-100 p-3 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-medium"><%= current_user.name %></h3>
          <p class="text-gray-600"><%= current_user.email %></p>
        </div>
      </div>

      <%= link_to "Edit Profile", edit_user_path(current_user),
                  class: "w-full bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 text-center" %>
    </div>
  </div>

  <!-- Upcoming Sessions Card -->
  <div class="bg-white shadow rounded-lg overflow-hidden md:col-span-2">
    <div class="p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-semibold">Upcoming Sessions</h2>
        <%= link_to "View All", student_sessions_path, class: "text-purple-600 hover:text-purple-800" %>
      </div>

      <% if @upcoming_sessions.present? %>
        <ul class="divide-y divide-gray-200">
          <% @upcoming_sessions.each do |session| %>
            <li class="py-4">
              <div class="flex justify-between">
                <div>
                  <p class="font-medium">
                    <%= session.start_time.strftime("%A, %B %d, %Y") %>
                  </p>
                  <p class="text-gray-600">
                    <%= session.start_time.strftime("%I:%M %p") %> -
                    <%= session.end_time.strftime("%I:%M %p") %>
                  </p>
                  <p class="text-gray-800">
                    Coach: <%= session.coach_profile.user.name %>
                  </p>
                </div>
                <div class="flex items-center">
                  <%= link_to "View Details", coaching_session_path(session),
                              class: "inline-block bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm" %>

                  <%= button_to "Cancel", booking_path(session.availability),
                                method: :delete,
                                data: { confirm: "Are you sure you want to cancel this session?" },
                                class: "ml-2 inline-block bg-red-100 text-red-800 px-3 py-1 rounded-full text-sm" %>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="text-center py-6 bg-gray-50 rounded">
          <p class="text-gray-500">You don't have any upcoming sessions.</p>
          <p class="mt-2">
            <%= link_to "Find a coach", coach_browser_index_path,
                        class: "text-purple-600 hover:text-purple-800" %>
          </p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Find a Coach Card -->
  <div class="bg-white shadow rounded-lg overflow-hidden md:col-span-3">
    <div class="p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-semibold">Available Coaches</h2>
        <%= link_to "Browse All Coaches", coach_browser_index_path,
                    class: "text-purple-600 hover:text-purple-800" %>
      </div>

      <% if @available_coaches.present? %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @available_coaches.each do |coach| %>
            <div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
              <div class="flex items-center mb-3">
                <div class="bg-gray-200 h-10 w-10 rounded-full flex items-center justify-center text-gray-700 font-bold">
                  <%= coach.name.first.upcase %>
                </div>
                <div class="ml-3">
                  <h3 class="font-medium"><%= coach.name %></h3>
                </div>
              </div>

              <p class="text-gray-600 text-sm mb-3 line-clamp-2">
                <%= coach.coach_profile.bio.present? ? coach.coach_profile.bio : "No bio available" %>
              </p>

              <%= link_to "View Profile", coach_browser_path(coach),
                          class: "block w-full bg-purple-100 text-purple-800 px-4 py-2 rounded text-center hover:bg-purple-200" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-6 bg-gray-50 rounded">
          <p class="text-gray-500">No coaches are available at this time.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>