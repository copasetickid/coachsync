<!-- app/views/home/_coach_dashboard.html.erb -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <!-- Profile Card -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="p-6">
      <h2 class="text-xl font-semibold mb-4">Your Profile</h2>
      <div class="flex items-center mb-4">
        <div class="bg-indigo-100 p-3 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-medium"><%= current_user.name %></h3>
          <p class="text-gray-600"><%= current_user.email %></p>
        </div>
      </div>

      <div class="mb-4">
        <div class="flex justify-between">
          <span class="text-gray-600">Profile Status:</span>
          <% if current_user.coach_profile.active? %>
            <span class="text-green-600 font-medium">Active</span>
          <% else %>
            <span class="text-red-600 font-medium">Inactive</span>
          <% end %>
        </div>
      </div>

      <div class="flex space-x-2">
        <%= link_to "View Profile", user_coach_profile_path(current_user),
                    class: "flex-1 bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 text-center" %>
        <%= link_to "Edit Profile", edit_user_coach_profile_path(current_user),
                    class: "flex-1 bg-gray-200 text-gray-800 px-4 py-2 rounded hover:bg-gray-300 text-center" %>
      </div>
    </div>
  </div>

  <!-- Upcoming Sessions Card -->
  <div class="bg-white shadow rounded-lg overflow-hidden md:col-span-2">
    <div class="p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-semibold">Upcoming Sessions</h2>
        <%= link_to "View All Sessions", session_feedbacks_path, class: "text-indigo-600 hover:text-indigo-800" %>

      </div>

      <% if @upcoming_sessions.present? %>
        <ul class="divide-y divide-gray-200">
          <% @upcoming_sessions.each do |session| %>
            <li class="py-4">
              <div class="flex justify-between">
                <div>
                  <p class="font-medium">
                    <%= session.start_time.strftime("%A, %B %d, %Y") %>
                  </p>
                  <p class="text-gray-600">
                    <%= session.start_time.strftime("%I:%M %p") %> -
                    <%= session.end_time.strftime("%I:%M %p") %>
                  </p>
                  <p class="text-gray-800">
                    Student: <%= session.student_name %>
                  </p>
                </div>
                <div>
                  <%= link_to "View Details", coaching_session_path(session.id),
                              class: "inline-block bg-indigo-100 text-indigo-800 px-3 py-1 rounded-full text-sm" %>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="text-center py-6 bg-gray-50 rounded">
          <p class="text-gray-500">You don't have any upcoming sessions.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Pending Feedback Card -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-semibold">Pending Feedback</h2>
        <%= link_to "View All", session_feedbacks_path, class: "text-indigo-600 hover:text-indigo-800" %>
      </div>

      <% if @pending_feedback.present? %>
        <ul class="divide-y divide-gray-200">
          <% @pending_feedback.each do |session| %>
            <li class="py-4">
              <div class="flex justify-between">
                <div>
                  <p class="font-medium">
                    <%= session.start_time.strftime("%A, %B %d") %>
                  </p>
                  <p class="text-gray-600">
                    Student: <%= session.student_name %>
                  </p>
                </div>
                <div>
                  <%= link_to "Add Feedback", edit_session_feedback_path(session),
                              class: "inline-block bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full text-sm" %>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="text-center py-6 bg-gray-50 rounded">
          <p class="text-gray-500">No pending feedback.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Availability Management Card -->
  <div class="bg-white shadow rounded-lg overflow-hidden md:col-span-2">
    <div class="p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-semibold">Availability Management</h2>
        <%= link_to "Manage Availability", coach_availabilities_path(current_user),
                    class: "text-indigo-600 hover:text-indigo-800" %>
      </div>

      <div class="flex justify-between items-center mb-4">
        <div>
          <p class="text-gray-600">Next 5 available slots:</p>
        </div>
        <div>
          <%= link_to "Add New Slot", new_coach_availability_path(current_user),
                      class: "inline-block bg-green-600 text-white px-3 py-1 rounded-md text-sm" %>
        </div>
      </div>

      <% if current_user.coach_profile.availabilities.upcoming.available.any? %>
        <ul class="divide-y divide-gray-200">
          <% current_user.coach_profile.availabilities.upcoming.available.order(start_time: :asc).limit(5).each do |slot| %>
            <li class="py-3">
              <div class="flex justify-between">
                <div>
                  <p class="font-medium">
                    <%= slot.start_time.strftime("%A, %B %d") %>
                  </p>
                  <p class="text-gray-600">
                    <%= slot.start_time.strftime("%I:%M %p") %> -
                    <%= slot.end_time.strftime("%I:%M %p") %>
                  </p>
                </div>
                <div>
                  <span class="inline-block bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm">
                    Available
                  </span>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="text-center py-6 bg-gray-50 rounded">
          <p class="text-gray-500">You don't have any available slots.</p>
          <p class="mt-2">
            <%= link_to "Add your first availability", new_coach_availability_path(current_user),
                        class: "text-indigo-600 hover:text-indigo-800" %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>