<div class="container mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold mb-6">My Coaching Sessions</h1>

  <!-- Upcoming Sessions -->
  <div class="bg-white shadow rounded-lg overflow-hidden mb-8">
    <div class="bg-gray-50 px-4 py-5 border-b border-gray-200 sm:px-6">
      <h2 class="text-lg font-medium text-gray-900">
        Upcoming Sessions
      </h2>
    </div>

    <% if @upcoming_bookings.empty? %>
      <div class="p-6 text-center">
        <p class="text-gray-500">You don't have any upcoming sessions.</p>
        <%= link_to "Find a Coach", coach_browser_index_path,
                    class: "inline-block mt-3 text-indigo-600 hover:text-indigo-800" %>
      </div>
    <% else %>
      <ul class="divide-y divide-gray-200">
        <% @upcoming_bookings.each do |booking| %>
          <li class="p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="font-medium"><%= booking.date_string %></p>
                <p class="text-gray-600"><%= booking.time_range_string %></p>
                <p class="mt-1">Coach: <%= booking.coach_name %></p>
              </div>

              <!-- Show coach phone number if available -->
              <% if booking.coach_profile.phone_number.present? %>
                <p class="text-gray-600 text-sm mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <%= booking.coach_profile.phone_number %>
                </p>
              <% end %>

              <div class="flex space-x-3">
                <%= link_to "View Details", coaching_session_path(booking.coaching_session),
                            class: "text-indigo-600 hover:text-indigo-800" %>
                <%= button_to "Cancel Booking", booking_path(booking),
                              method: :delete,
                              data: { confirm: "Are you sure you want to cancel this session?" },
                              class: "bg-red-100 hover:bg-red-200 text-red-800 py-2 px-4 rounded" %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>

  <!-- Past Sessions -->
  <% if @past_bookings.any? %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="bg-gray-50 px-4 py-5 border-b border-gray-200 sm:px-6">
        <h2 class="text-lg font-medium text-gray-900">
          Past Sessions
        </h2>
      </div>

      <ul class="divide-y divide-gray-200">
        <% @past_bookings.each do |booking| %>
          <li class="p-6">
            <div>
              <p class="font-medium"><%= booking.date_string %></p>
              <p class="text-gray-600"><%= booking.time_range_string %></p>
              <p class="mt-1">Coach: <%= booking.coach_name %></p>

              <% if booking.coaching_session&.status == 'completed' %>
                <p class="mt-2 text-sm text-green-600">Completed</p>
              <% else %>
                <p class="mt-2 text-sm text-yellow-600">Attended</p>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>

